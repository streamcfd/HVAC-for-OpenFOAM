FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      ASHRAE55Dict;
}

// ASHRAE 55 evaluation model:
// - adaptive: naturally ventilated adaptive comfort model
// - pmv: PMV-based method for indoor conditioned spaces
model       adaptive;

// PMV-mode defaults. Command-line options override these values.
met         1.2;
clo         0.5;
wme         0.0;
RH          50;

