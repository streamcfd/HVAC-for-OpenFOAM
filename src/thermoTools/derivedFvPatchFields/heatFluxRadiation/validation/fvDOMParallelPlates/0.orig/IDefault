FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      IDefault;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 0 -3 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    yLow
    {
        type            cyclic;
    }

    yHigh
    {
        type            cyclic;
    }

    zLow
    {
        type            cyclic;
    }

    zHigh
    {
        type            cyclic;
    }

    hot
    {
        type            greyDiffusiveRadiation;
        value           uniform 0;
    }

    cold
    {
        type            greyDiffusiveRadiation;
        value           uniform 0;
    }
}


