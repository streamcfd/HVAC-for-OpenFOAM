FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    yLow
    {
        type            cyclic;
    }

    yHigh
    {
        type            cyclic;
    }

    zLow
    {
        type            cyclic;
    }

    zHigh
    {
        type            cyclic;
    }

    hot
    {
        type            noSlip;
    }

    cold
    {
        type            noSlip;
    }
}


