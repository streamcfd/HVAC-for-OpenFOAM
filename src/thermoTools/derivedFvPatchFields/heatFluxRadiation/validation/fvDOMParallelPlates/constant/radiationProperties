FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      radiationProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

radiation       on;

radiationModel  fvDOM;

fvDOMCoeffs
{
    nPhi        8;
    nTheta      8;
    tolerance   1e-8;
    maxIter     100;
}

solverFreq 1;

absorptionEmissionModel none;

scatterModel    none;

sootModel       none;


